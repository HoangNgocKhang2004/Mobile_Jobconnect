                            <th>Loại</th>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Cập nhật trạng thái hồ sơ</td>
                            <td>Nguyễn Văn A</td>
                            <td>Cập nhật ứng tuyển</td>
                            <td>15/04/2025 10:30</td>
                            <td><span class="status status-sent">Đã gửi</span></td>
                            <td>
                                <button class="btn btn-secondary">Chi tiết</button>
                            </td>
                        </tr>
                        <tr>
                            <td>Nhắc nhở phỏng vấn</td>
                            <td>Trần Thị B</td>
                            <td>Phỏng vấn</td>
                            <td>16/04/2025 09:00</td>
                            <td><span class="status status-scheduled">Lên lịch</span></td>
                            <td>
                                <button class="btn btn-secondary">Chi tiết</button>
                            </td>
                        </tr>
                        <tr>
                            <td>Hồ sơ được chấp nhận</td>
                            <td>Lê Văn C</td>
                            <td>Cập nhật ứng tuyển</td>
                            <td>14/04/2025 14:45</td>
                            <td><span class="status status-sent">Đã gửi</span></td>
                            <td>
                                <button class="btn btn-secondary">Chi tiết</button>
                            </td>
                        </tr>
                        <tr>
                            <td>Mời ứng tuyển vị trí mới</td>
                            <td>Phạm Thị D</td>
                            <td>Việc làm mới</td>
                            <td>17/04/2025 08:30</td>
                            <td><span class="status status-scheduled">Lên lịch</span></td>
                            <td>
                                <button class="btn btn-secondary">Chi tiết</button>
                            </td>
                        </tr>
                        <tr>
                            <td>Lời mời phỏng vấn</td>
                            <td>Hoàng Văn E</td>
                            <td>Phỏng vấn</td>
                            <td>15/04/2025 16:00</td>
                            <td><span class="status status-pending">Chờ xử lý</span></td>
                            <td>
                                <button class="btn btn-secondary">Chi tiết</button>
                            </td>
                        </tr>
                        <tr>
                            <td>Thông báo tạm dừng tuyển dụng</td>
                            <td>Công ty ABC</td>
                            <td>Thông báo chung</td>
                            <td>13/04/2025 11:20</td>
                            <td><span class="status status-failed">Lỗi</span></td>
                            <td>
                                <button class="btn btn-secondary">Chi tiết</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="pagination">
                <a href="#" class="pagination-item">«</a>
                <a href="#" class="pagination-item active">1</a>
                <a href="#" class="pagination-item">2</a>
                <a href="#" class="pagination-item">3</a>
                <a href="#" class="pagination-item">»</a>
            </div>
        </div>
    </div>
</div>

<!-- Modal tạo thông báo mới -->
<div class="modal" id="createNotificationModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Tạo thông báo mới</h3>
            <button class="close-button" id="closeModalBtn">&times;</button>
        </div>

        <form id="notificationForm">
            <div class="form-group">
                <label class="form-label">Loại thông báo</label>
                <select class="form-control">
                    <option value="">Chọn loại thông báo</option>
                    <option value="update">Cập nhật ứng tuyển</option>
                    <option value="interview">Phỏng vấn</option>
                    <option value="job">Việc làm mới</option>
                    <option value="general">Thông báo chung</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Đối tượng nhận</label>
                <select class="form-control">
                    <option value="">Chọn đối tượng</option>
                    <option value="candidate">Ứng viên cụ thể</option>
                    <option value="employer">Nhà tuyển dụng cụ thể</option>
                    <option value="all_candidates">Tất cả ứng viên</option>
                    <option value="all_employers">Tất cả nhà tuyển dụng</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Tiêu đề</label>
                <input type="text" class="form-control" placeholder="Nhập tiêu đề thông báo">
            </div>

            <div class="form-group">
                <label class="form-label">Nội dung</label>
                <textarea class="form-control" placeholder="Nhập nội dung thông báo"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Thời gian gửi</label>
                <select class="form-control" id="sendTimeOption">
                    <option value="now">Gửi ngay</option>
                    <option value="schedule">Lên lịch gửi</option>
                </select>
            </div>

            <div class="form-group" id="scheduleTimeGroup" style="display: none;">
                <label class="form-label">Thời gian lên lịch</label>
                <input type="datetime-local" class="form-control">
            </div>

            <div class="form-actions">
                <button type="button" class="btn btn-secondary" id="cancelBtn">Hủy</button>
                <button type="submit" class="btn btn-primary">Tạo thông báo</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Xử lý hiển thị modal
    const createNotificationBtn = document.getElementById('createNotificationBtn');
    const closeModalBtn = document.getElementById('closeModalBtn');
    const cancelBtn = document.getElementById('cancelBtn');
    const createNotificationModal = document.getElementById('createNotificationModal');

    createNotificationBtn.addEventListener('click', () => {
        createNotificationModal.classList.add('active');
    });

    closeModalBtn.addEventListener('click', () => {
        createNotificationModal.classList.remove('active');
    });

    cancelBtn.addEventListener('click', () => {
        createNotificationModal.classList.remove('active');
    });

    // Xử lý hiển thị trường lên lịch
    const sendTimeOption = document.getElementById('sendTimeOption');
    const scheduleTimeGroup = document.getElementById('scheduleTimeGroup');

    sendTimeOption.addEventListener('change', () => {
        if (sendTimeOption.value === 'schedule') {
            scheduleTimeGroup.style.display = 'block';
        } else {
            scheduleTimeGroup.style.display = 'none';
        }
    });

    // Xử lý chuyển tab
    const tabs = document.querySelectorAll('.tab');

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
        });
    });
</script>