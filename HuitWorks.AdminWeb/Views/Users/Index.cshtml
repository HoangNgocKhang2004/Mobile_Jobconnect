                                <td>15/04/2025</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="action-btn">Xem</button>
                                        <button class="action-btn">Sửa</button>
                                        <button class="action-btn">Khóa</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>002</td>
                                <td>Trần Thị B</td>
                                <td>tranthib@email.com</td>
                                <td>0987654321</td>
                                <td><span class="badge badge-secondary">Nhà tuyển dụng</span></td>
                                <td><span class="status active">Hoạt động</span></td>
                                <td>14/04/2025</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="action-btn">Xem</button>
                                        <button class="action-btn">Sửa</button>
                                        <button class="action-btn">Khóa</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>003</td>
                                <td>Lê Văn C</td>
                                <td>levanc@email.com</td>
                                <td>0978123456</td>
                                <td><span class="badge badge-primary">Ứng viên</span></td>
                                <td><span class="status pending">Chờ xác thực</span></td>
                                <td>13/04/2025</td>
                                <td>
                                    <div class="action-buttons">
