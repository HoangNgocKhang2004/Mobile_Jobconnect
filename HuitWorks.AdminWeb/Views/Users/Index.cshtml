                                <td>0965432189</td>
                                <td><span class="badge badge-secondary">Nhà tuyển dụng</span></td>
                                <td><span class="status locked">Đã khóa</span></td>
                                <td>12/04/2025</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="action-btn">Xem</button>
