                        <img src="~/images/default.png" alt="AI trong tuyển dụng">
                    </div>
                    <div class="p-6">
                        <div class="flex flex-wrap gap-2 mb-3">
                            <span class="tag bg-red-100 text-red-700">Công nghệ</span>
