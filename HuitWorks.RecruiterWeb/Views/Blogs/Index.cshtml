                                Đọc tiếp <i class="fas fa-arrow-right ml-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <div class="mt-12 flex justify-center">
                <div class="inline-flex bg-white shadow-md rounded-lg overflow-hidden">
                    <button class="px-4 py-2 border-r border-gray-200 hover:bg-indigo-50 flex items-center justify-center text-gray-500 hover:text-indigo-700 transition duration-300">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="w-10 h-10 flex items-center justify-center bg-indigo-600 text-white">1</button>
                    <button class="w-10 h-10 flex items-center justify-center hover:bg-indigo-50 text-gray-700 hover:text-indigo-700 transition duration-300">2</button>
                    <button class="w-10 h-10 flex items-center justify-center hover:bg-indigo-50 text-gray-700 hover:text-indigo-700 transition duration-300">3</button>
                    <button class="px-4 py-2 border-l border-gray-200 hover:bg-indigo-50 flex items-center justify-center text-gray-500 hover:text-indigo-700 transition duration-300">
