                        <img src="~/images/default.png" alt="Làm việc từ xa">
                    </div>
                    <div class="p-6">
                        <div class="flex flex-wrap gap-2 mb-3">
                            <span class="tag bg-green-100 text-green-700">Xu hướng</span>
                            <div class="flex items-center text-gray-500 text-sm">
                                <i class="far fa-calendar-alt mr-1"></i>
                                03/04/2025
