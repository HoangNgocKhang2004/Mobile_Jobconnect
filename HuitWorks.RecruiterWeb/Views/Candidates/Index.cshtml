                    <span class="badge bg-primary me-2">15 ứng viên</span>
                    <div class="btn-group">
                        <button class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-download me-1"></i>Xuất Excel
                        </button>
                        <button class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-print me-1"></i>In
                        </button>
                    </div>
                </div>
            </div>
        </div>
