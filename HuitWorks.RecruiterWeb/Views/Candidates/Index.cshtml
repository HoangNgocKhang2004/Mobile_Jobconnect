@{
    ViewData["Title"] = "Quản lý danh sách ứng viên";
}
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>


<div class="container py-4">
    <!-- Bộ lọc và tìm kiếm -->
    <div class="card mb-4">
        <div class="card-header bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Tìm kiếm và lọc ứng viên</h5>
                <button class="btn btn-sm btn-link" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
                    <i class="fas fa-chevron-down"></i>
                </button>
            </div>
        </div>
        <div class="collapse show" id="filterCollapse">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Từ khóa</label>
                            <input type="text" class="form-control" placeholder="Tên, kỹ năng, vị trí...">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Vị trí ứng tuyển</label>
                            <select class="form-select">
                                <option selected>Tất cả vị trí</option>
                                <option>Lập trình viên Frontend</option>
                                <option>Lập trình viên Backend</option>
                                <option>Quản lý dự án</option>
                                <option>UI/UX Designer</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Kinh nghiệm</label>
                            <select class="form-select">
                                <option selected>Tất cả</option>
                                <option>Dưới 1 năm</option>
                                <option>1-3 năm</option>
                                <option>3-5 năm</option>
                                <option>Trên 5 năm</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Kỹ năng</label>
                            <select class="form-select">
                                <option selected>Tất cả</option>
                                <option>JavaScript</option>
                                <option>React</option>
                                <option>Angular</option>
                                <option>Vue.js</option>
                                <option>.NET</option>
                                <option>Java</option>
                                <option>Python</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Trạng thái</label>
                            <select class="form-select">
                                <option selected>Tất cả</option>
                                <option>Mới nộp hồ sơ</option>
                                <option>Đang xem xét</option>
                                <option>Đã mời phỏng vấn</option>
                                <option>Đã phỏng vấn</option>
                                <option>Đã nhận việc</option>
                                <option>Từ chối</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Mức điểm AI</label>
                            <select class="form-select">
                                <option selected>Tất cả</option>
                                <option>90% - 100%</option>
                                <option>80% - 89%</option>
                                <option>70% - 79%</option>
                                <option>Dưới 70%</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col">
                        <button class="btn btn-primary">
                            <i class="fas fa-search me-2"></i>Tìm kiếm
                        </button>
                        <button class="btn btn-outline-secondary ms-2">
                            <i class="fas fa-redo me-2"></i>Đặt lại
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Kết quả tìm kiếm -->
    <div class="card mb-4">
        <div class="card-header bg-white">
            <div class="d-flex justify-content-between align-items-center">
