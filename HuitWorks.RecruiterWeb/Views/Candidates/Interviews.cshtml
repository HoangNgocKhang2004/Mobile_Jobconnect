@model IEnumerable<HuitWorks.RecruiterWeb.Models.InterviewViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý lịch phỏng vấn";
}

<div class="container-fluid py-4">
    <div class="card shadow">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-primary fw-bold">Quản lý lịch phỏng vấn</h5>
                <a asp-action="Create" class="btn btn-primary">
                    Tạo lịch phỏng vấn
                </a>
            </div>
        </div>

        <div class="card-body">
            <!-- Bộ lọc và tìm kiếm -->
            <div class="row mb-4 g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" />
                            </svg>
                        </span>
                        <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm ứng viên...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select id="statusFilter" class="form-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Đang chờ">Đang chờ</option>
                        <option value="Đã hoàn thành">Đã hoàn thành</option>
                        <option value="Hủy">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" id="dateFilter" class="form-control" placeholder="Chọn ngày">
                </div>
                <div class="col-md-2">
                    <button id="resetFilters" class="btn btn-outline-secondary w-100">
                        Làm mới
                    </button>
                </div>
            </div>

            <!-- Bảng lịch phỏng vấn -->
            <div class="table-responsive">
                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <div class="text-secondary mb-3" style="font-size: 48px;">📅</div>
                        <h5 class="mt-3 text-secondary">Chưa có cuộc phỏng vấn nào được lên lịch</h5>
                        <p class="text-muted">Nhấn "Tạo lịch phỏng vấn" để bắt đầu</p>
                    </div>
                }
                else
                {
                    <table class="table table-hover align-middle" id="interviewTable">
                        <thead class="table-light">
                            <tr>
                                <th class="sortable" data-sort="candidate">
                                    Ứng viên <span class="text-secondary ms-1">↕</span>
                                </th>
                                <th class="sortable" data-sort="position">
                                    Vị trí <span class="text-secondary ms-1">↕</span>
                                </th>
                                <th class="sortable" data-sort="datetime">
                                    Thời gian <span class="text-secondary ms-1">↕</span>
                                </th>
                                <th>Hình thức</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="interview-row"
                                    data-candidate="@item.CandidateName.ToLower()"
                                    data-position="@item.PositionTitle.ToLower()"
                                    data-status="@item.Status"
                                    data-date="@item.InterviewDateTime.ToString("yyyy-MM-dd")">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-initials bg-light text-primary rounded-circle me-2">
                                                @(item.CandidateName.Length > 0 ? item.CandidateName[0].ToString().ToUpper() : "")
                                            </div>
                                            <div>
                                                <div class="fw-medium">@item.CandidateName</div>
                                                @if (!string.IsNullOrEmpty(item.CandidateEmail))
                                                {
                                                    <div class="small text-muted">@item.CandidateEmail</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>@item.PositionTitle</td>
                                    <td>
                                        <div>@item.InterviewDateTime.ToString("dd/MM/yyyy")</div>
                                        <div class="small text-muted">@item.InterviewDateTime.ToString("HH:mm")</div>
                                    </td>
                                    <td>
                                        @if (item.Mode == "Online")
                                        {
                                            <span class="badge bg-info text-dark">
                                                Online
                                            </span>
                                        }
                                        else if (item.Mode == "Offline")
                                        {
                                            <span class="badge bg-secondary text-white">
                                                Tại văn phòng
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark">@item.Mode</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(item.Status == "Đã hoàn thành" ? "bg-success" :
                                                             item.Status == "Đang chờ" ? "bg-warning text-dark" :
                                                             item.Status == "Hủy" ? "bg-danger" : "bg-secondary")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                                Xem
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Chỉnh sửa">
                                                Sửa
                                            </a>
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-dark dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                    Khác
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li>
                                                        <a class="dropdown-item" href="javascript:void(0)" onclick="sendReminder(@item.Id)">
                                                            Gửi nhắc nhở
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item" href="javascript:void(0)" onclick="scheduleCalendar(@item.Id)">
                                                            Thêm vào lịch
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id">
                                                            Xóa
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="card-footer bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                        Tổng số: <span class="fw-bold" id="totalCount">@Model.Count()</span> cuộc phỏng vấn
                    </div>
                    <div>
                        <button class="btn btn-sm btn-outline-primary" id="exportBtn">
                            Xuất dữ liệu
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tìm kiếm
            $("#searchInput").on("keyup", filterInterviews);
            $("#statusFilter").on("change", filterInterviews);
            $("#dateFilter").on("change", filterInterviews);

            // Reset bộ lọc
            $("#resetFilters").click(function() {
                $("#searchInput").val('');
                $("#statusFilter").val('');
                $("#dateFilter").val('');
                filterInterviews();
            });

            // Sắp xếp
            $(".sortable").click(function() {
                const column = $(this).data("sort");
                sortTable(column);
            });

            // Xuất dữ liệu
            $("#exportBtn").click(function() {
                alert("Tính năng xuất dữ liệu đang được phát triển");
            });

            function filterInterviews() {
                const searchText = $("#searchInput").val().toLowerCase();
                const statusFilter = $("#statusFilter").val();
                const dateFilter = $("#dateFilter").val();
                let visibleCount = 0;

                $(".interview-row").each(function() {
                    const candidate = $(this).data("candidate");
                    const position = $(this).data("position");
                    const status = $(this).data("status");
                    const date = $(this).data("date");

                    const matchesSearch = candidate.includes(searchText) || position.includes(searchText);
                    const matchesStatus = !statusFilter || status === statusFilter;
                    const matchesDate = !dateFilter || date === dateFilter;

                    if (matchesSearch && matchesStatus && matchesDate) {
                        $(this).show();
                        visibleCount++;
                    } else {
                        $(this).hide();
                    }
                });

                $("#totalCount").text(visibleCount);
            }

            function sortTable(column) {
                // Thêm logic sắp xếp theo cột ở đây
                console.log("Sorting by", column);
            }
        });

        function sendReminder(id) {
            alert("Đang gửi nhắc nhở cho cuộc phỏng vấn #" + id);
        }

        function scheduleCalendar(id) {
            alert("Đang thêm cuộc phỏng vấn #" + id + " vào lịch");
        }
    </script>

    <style>
        .avatar-initials {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .sortable {
            cursor: pointer;
        }

            .sortable:hover {
                background-color: rgba(0,0,0,0.03);
            }
    </style>
}