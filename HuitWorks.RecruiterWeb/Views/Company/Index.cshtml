@{
    ViewData["Title"] = "Quản lý tài khoản";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .dashboard-container {
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    .card {
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        margin-bottom: 20px;
        border: none;
    }

    .card-header {
        background-color: #fff;
        border-bottom: 1px solid #eee;
        padding: 15px 20px;
        font-weight: 600;
        border-radius: 10px 10px 0 0 !important;
    }

    .nav-pills .nav-link {
        border-radius: 5px;
        padding: 12px 20px;
        color: #495057;
        margin-bottom: 8px;
    }

        .nav-pills .nav-link.active {
            background-color: #0d6efd;
            color: white;
        }

    .tab-content {
        padding: 20px;
        background-color: #fff;
        border-radius: 10px;
    }

    .company-logo {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eee;
        display: inline;
    }

    .premium-badge {
        background-color: #ffc107;
        color: #212529;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-status {
        padding: 6px 10px;
        border-radius: 20px;
        font-weight: 500;
    }

    .btn-action {
        border-radius: 5px;
        padding: 6px 12px;
        margin-right: 5px;
    }

    .table th {
        font-weight: 600;
        color: #495057;
    }

    .avatar-sm {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
    }

    .package-card {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 20px;
        transition: all 0.3s;
        height: 100%;
    }

        .package-card:hover {
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            transform: translateY(-5px);
        }

    .package-popular {
        border: 2px solid #0d6efd;
    }
</style>
<!-- Body content starts here -->
<div class="dashboard-container">
    <div class="container">
        <div class="row">
            <!-- Sidebar Navigation -->
            <div class="col-lg-3">
                <div class="card mb-4">
