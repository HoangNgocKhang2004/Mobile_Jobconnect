                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-9">
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label class="form-label">Tên công ty</label>
                                                    <input type="text" class="form-control" value="Công ty ABC">
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Lĩnh vực</label>
                                                    <select class="form-select">
                                                        <option selected>Công nghệ thông tin</option>
                                                        <option>Tài chính - Ngân hàng</option>
                                                        <option>Giáo dục - Đào tạo</option>
                                                        <option>Thương mại điện tử</option>
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Email</label>
                                                    <input type="email" class="form-control" value="contact@abc.com">
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Số điện thoại</label>
                                                    <input type="tel" class="form-control" value="0123456789">
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <h5 class="mb-3">Thông tin chi tiết</h5>
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6">
                                            <label class="form-label">Website</label>
                                            <input type="url" class="form-control" value="https://abc.com">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Quy mô nhân sự</label>
                                            <select class="form-select">
                                                <option>Dưới 10 nhân viên</option>
                                                <option selected>10-50 nhân viên</option>
                                                <option>51-200 nhân viên</option>
                                                <option>201-500 nhân viên</option>
                                                <option>Trên 500 nhân viên</option>
                                            </select>
                                        </div>
                                        <div class="col-md-12">
                                            <label class="form-label">Địa chỉ</label>
