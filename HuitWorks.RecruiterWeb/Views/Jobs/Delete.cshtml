@model Job
@{
    ViewData["Title"] = "Xóa bài tuyển dụng";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .header-container {
        border-left: 4px solid #4e73df;
        transition: all 0.3s ease;
    }

        .header-container:hover {
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .hover-text-primary:hover {
        color: #4e73df !important;
        transition: color 0.3s ease;
    }

    .fs-14 {
        font-size: 14px;
    }

    h1.text-primary {
        color: #4e73df;
    }

    .hover-scale {
        transition: transform 0.2s ease;
    }

        .hover-scale:hover {
            transform: scale(1.05);
        }

    .btn-outline-primary {
        border-color: #4e73df;
        color: #4e73df;
    }

        .btn-outline-primary:hover {
            background-color: #4e73df;
            color: white;
        }
</style>
<div class="container-fluid p-4">
    <div class="header-container bg-white shadow-sm rounded p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div class="header-content">
                <h1 class="fw-bold text-primary mb-2">XÓA BÀI TUYỂN DỤNG</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 fs-14">
                        <li class="breadcrumb-item">
                            <a asp-action="Index" class="text-decoration-none text-secondary hover-text-primary">
                                <i class="fas fa-home me-1"></i>Quản lý tuyển dụng
                            </a>
                        </li>
                        <li class="breadcrumb-item active fw-semibold" aria-current="page">Xóa</li>
                    </ol>
                </nav>
            </div>
            <div class="header-actions">
                <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 hover-scale">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Xác nhận xóa</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Cảnh báo:</strong> Bạn có chắc chắn muốn xóa bài tuyển dụng này? Hành động này không thể hoàn tác.
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Thông tin bài tuyển dụng</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5>@Model.Title</h5>
                            <p class="text-muted">
                                <i class="fas fa-map-marker-alt me-1"></i>@Model.Location<br>
                                <i class="fas fa-money-bill-wave me-1"></i>@Model.Salary
                            </p>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item d-flex justify-content-between px-0">
                                    <span>ID:</span>
                                    <span>@Model.Id</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between px-0">
                                    <span>Ngày đăng:</span>
                                    <span>@Model.PostedDate.ToString("dd/MM/yyyy")</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between px-0">
                                    <span>Ngày hết hạn:</span>
                                    <span>@Model.ExpiryDate.ToString("dd/MM/yyyy")</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between px-0">
                                    <span>Trạng thái:</span>
                                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                                        @(Model.IsActive ? "Đang hoạt động" : "Đã tắt")
                                    </span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times me-1"></i>Hủy
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Xác nhận xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>