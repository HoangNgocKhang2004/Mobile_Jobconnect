                    </li>
                    <li class="nav-item nav-dropdown">
                        <a class="nav-link" href="#companySubmenu">
                            <div class="icon-container">
                                <i class="fas fa-building"></i>
                            </div>
                            <span>Hồ sơ công ty</span>
                        </a>
                        <ul class="sidebar-submenu" id="companySubmenu">
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Index" && ViewContext.RouteData.Values["Controller"].ToString() == "Company" ? "active" : "")"
                                   asp-area="" asp-controller="Company" asp-action="Index">
                                    Thông tin công ty
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Team" && ViewContext.RouteData.Values["Controller"].ToString() == "Company" ? "active" : "")"
                                   asp-area="" asp-controller="Company" asp-action="Team">
                                    Đội ngũ
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Gallery" && ViewContext.RouteData.Values["Controller"].ToString() == "Company" ? "active" : "")"
                                   asp-area="" asp-controller="Company" asp-action="Gallery">
                                    Thư viện ảnh
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Transactions" ? "active" : "")"
                           asp-area="" asp-controller="Transactions" asp-action="Index">
                            <div class="icon-container">
                                <i class="fas fa-money-check-alt"></i>
                            </div>
                            <span>Giao dịch</span>
                            <span class="badge rounded-pill bg-success transaction-badge">
                                2
                            </span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Contact" ? "active" : "")"
                           asp-area="" asp-controller="Contact" asp-action="Index">
                            <div class="icon-container">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <span>Liên hệ</span>
                        </a>
                    </li>
                </ul>
                
            </div>

            <div class="sidebar-user-info">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="d-flex align-items-center">
                        <div class="user-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <div class="user-details">
                            <div class="fw-bold">@User.Identity.Name</div>
                            <div class="dropdown">
                                <a class="dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Tùy chọn
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="Profile">Hồ sơ</a></li>
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="Settings">Cài đặt</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item">Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-primary btn-sm" asp-area="" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                        <a class="btn btn-primary btn-sm" asp-area="" asp-controller="Auth" asp-action="Register">Đăng ký</a>
                    </div>
                }
            </div>
        </nav>
        
        <!-- Main Content -->
        <div class="main-content flex-grow-1" id="mainContent">
            <!-- Top header with contact info -->
            <div class="top-header border-bottom py-2">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-8">
                            <span class="me-4"><i class="fas fa-phone-alt me-2"></i>+84 33 429 7551</span>
                            <span><i class="fas fa-envelope me-2"></i>career@huitworks.vn</span>
                        </div>
                        <div class="col-md-4 text-end">
                            <a href="#" class="me-3"><i class="fab fa-facebook"></i></a>
                            <a href="#" class="me-3"><i class="fab fa-linkedin"></i></a>
                            <a href="#"><i class="fab fa-twitter"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Page Content -->
            <div class="page-content p-4">
                @RenderBody()
            </div>

            @* <!-- Footer --> *@
            @* <footer class="footer mt-auto py-3 bg-light"> *@
            @*     <div class="container text-center"> *@
            @*         <p class="mb-0">&copy; @DateTime.Now.Year - HuitWorks Recruitment Platform - All Rights Reserved</p> *@
            @*     </div> *@
            @* </footer> *@
        </div>
    </div>

    <!-- Chat Button and Container -->
    <div class="chatbox-button" id="chatboxButton">
        <i class="fas fa-comment-dots fa-lg"></i>
    </div>

    <div class="chatbox-container" id="chatboxContainer">
        <div class="chatbox-header">
            <h5 class="mb-0">HuitWorks Support</h5>
            <button class="chatbox-close" id="chatboxClose">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="chatbox-messages" id="chatboxMessages">
            <div class="chatbox-message chatbox-agent-message">
                Hello! How can I help you with HuitWorks recruitment services today?
            </div>
        </div>
        <div class="chatbox-input-container">
            <input type="text" class="chatbox-input" id="chatboxInput" placeholder="Type your message..." />
            <button class="chatbox-send-button" id="chatboxSendButton">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/js/all.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Enhanced JavaScript with animations -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle badge animation manually without keyframes
            function pulseAnimation() {
                const badge = document.getElementById('unreadMessagesBadge');
                if (!badge) return;
                
                let scale = 1;
                let growing = true;
                
                setInterval(function() {
                    if (growing) {
                        scale += 0.01;
                        if (scale >= 1.2) growing = false;
                    } else {
                        scale -= 0.01;
                        if (scale <= 1) growing = true;
                    }
                    
                    badge.style.transform = `scale(${scale})`;
                }, 20);
            }
            
            // Start badge animation
            pulseAnimation();
            
            // Sidebar Toggle Functionality
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            
            // Sidebar Dropdown Menus
            const dropdownToggles = document.querySelectorAll('.dropdown-toggle');
            
            dropdownToggles.forEach(function(toggle) {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    // Expand the submenu 
                    const targetId = this.getAttribute('href');
                    const target = document.querySelector(targetId);
                    
                    // Toggle the aria-expanded attribute
                    const isExpanded = this.getAttribute('aria-expanded') === 'true';
                    this.setAttribute('aria-expanded', !isExpanded);
                    
                    // Toggle show class on submenu
                    target.classList.toggle('show');
                    
                    
                });
            });
            
            // Auto-expand dropdown menu if child is active
            const activeLinks = document.querySelectorAll('.sidebar-submenu .nav-link.active');
            activeLinks.forEach(function(link) {
                const submenu = link.closest('.sidebar-submenu');
                if (submenu) {
                    submenu.classList.add('show');
                    const toggle = document.querySelector(`[href="#${submenu.id}"]`);
                    if (toggle) {
                        toggle.setAttribute('aria-expanded', 'true');
                    }
                }
            });
            
            // Create overlay for mobile view
            const overlay = document.createElement('div');
            overlay.className = 'overlay';
            document.body.appendChild(overlay);
            
            // Handle responsive layout
            function handleResponsive() {
                if (window.innerWidth <= 768) {
                    sidebar.classList.add('sidebar-mobile-hidden');
                    mainContent.classList.add('main-content-mobile');
                } else {
                    sidebar.classList.remove('sidebar-mobile-hidden');
                    sidebar.classList.remove('sidebar-show');
                    mainContent.classList.remove('main-content-mobile');
                    overlay.classList.remove('overlay-visible');
                }
            }
            
            // Apply on page load
            handleResponsive();
            
            // Apply on window resize
            window.addEventListener('resize', handleResponsive);
            
            // Mobile sidebar toggle
            const navbarToggler = document.querySelector('.navbar-toggler');
            if (navbarToggler) {
                navbarToggler.addEventListener('click', function() {
                    sidebar.classList.toggle('sidebar-show');
                    overlay.classList.toggle('overlay-visible');
                });
            }
            
            
            // Close sidebar when overlay is clicked
            overlay.addEventListener('click', function() {
                sidebar.classList.remove('sidebar-show');
                overlay.classList.remove('overlay-visible');
            });

            // Chatbox functionality
            const chatboxButton = document.getElementById('chatboxButton');
            const chatboxContainer = document.getElementById('chatboxContainer');
            const chatboxClose = document.getElementById('chatboxClose');
            const chatboxInput = document.getElementById('chatboxInput');
            const chatboxSendButton = document.getElementById('chatboxSendButton');
            const chatboxMessages = document.getElementById('chatboxMessages');

            // Toggle chat container visibility with animation
            chatboxButton.addEventListener('click', function() {
                chatboxContainer.style.display = 'flex';
                chatboxButton.style.display = 'none';
            });

            // Close chat container with animation
            chatboxClose.addEventListener('click', function() {
                chatboxContainer.style.animation = 'zoomOut 0.3s ease forwards';
                setTimeout(() => {
                    chatboxContainer.style.display = 'none';
                    chatboxButton.style.display = 'flex';
                    chatboxContainer.style.animation = 'zoomIn 0.3s ease';
                }, 300);
            });

            // Send message function
            function sendMessage() {
                const message = chatboxInput.value.trim();
                if (message !== '') {
                    // Add user message
                    addMessage(message, 'user');
                    chatboxInput.value = '';

                    // Simulate response (can be replaced with actual API call)
                    setTimeout(() => {
                        const responses = [
                            "Cảm ơn bạn đã liên hệ. Đội tuyển dụng của chúng tôi sẽ hỗ trợ bạn ngay.",
                            "Tôi hiểu câu hỏi của bạn. Hãy để tôi kết nối bạn với các chuyên gia của chúng tôi.",
                            "Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi lại với thông tin chi tiết về dịch vụ tuyển dụng của chúng tôi."
                        ];
                        const randomResponse = responses[Math.floor(Math.random() * responses.length)];
                        addMessage(randomResponse, 'agent');
                    }, 1000);
                }
            }

            // Add message to chat with animation
            function addMessage(text, sender) {
                const messageDiv = document.createElement('div');
                messageDiv.classList.add('chatbox-message');
                messageDiv.classList.add(sender === 'user' ? 'chatbox-user-message' : 'chatbox-agent-message');
                messageDiv.textContent = text;

                chatboxMessages.appendChild(messageDiv);
                chatboxMessages.scrollTop = chatboxMessages.scrollHeight;
            }

            // Send message on button click
            chatboxSendButton.addEventListener('click', sendMessage);

            // Send message on Enter key
            chatboxInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    sendMessage();
                }
            });

            // Xử lý hiển thị số tin nhắn chưa đọc
            function updateUnreadMessagesBadge(count) {
                const badge = document.getElementById('unreadMessagesBadge');
                if (badge) {
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.classList.remove('d-none');
                    } else {
                        badge.classList.add('d-none');
                    }
                }
            }

            // Xử lý hiển thị thông báo giao dịch mới
            function updateTransactionBadge(count) {
                const transactionBadge = document.querySelector('.transaction-badge');
                if (transactionBadge) {
                    if (count > 0) {
                        transactionBadge.textContent = count > 99 ? '99+' : count;
                        transactionBadge.classList.remove('d-none');
                        
                        // Thêm hiệu ứng nhấp nháy
                        transactionBadge.classList.add('badge-animation');
                        setTimeout(() => {
                            transactionBadge.classList.remove('badge-animation');
                        }, 5000);
                    } else {
                        transactionBadge.classList.add('d-none');
                    }
                }
            }

            // Giả lập việc lấy số tin nhắn chưa đọc (thay thế bằng API thực tế)
            function fetchUnreadMessagesCount() {
                // Đây là nơi bạn sẽ gọi API để lấy số tin nhắn chưa đọc
                // Ví dụ mẫu với số cố định
                const unreadCount = 3; // Thay thế bằng dữ liệu thực từ API
                updateUnreadMessagesBadge(unreadCount);
                
                // Giả lập gọi API lấy số thông báo giao dịch
                const transactionCount = 2; // Thay thế bằng dữ liệu thực
                updateTransactionBadge(transactionCount);
            }

            // Gọi hàm lấy số tin nhắn khi trang được tải
            fetchUnreadMessagesCount();

            // Thiết lập cập nhật định kỳ (ví dụ: mỗi 30 giây)
            setInterval(fetchUnreadMessagesCount, 30000);
            
            // Thêm hiệu ứng nhấp nháy khi có tin nhắn mới
            function notifyNewMessage() {
                const badge = document.getElementById('unreadMessagesBadge');
                badge.classList.add('badge-animation');
                setTimeout(() => {
                    badge.classList.remove('badge-animation');
                }, 5000); // Ngừng hiệu ứng sau 5 giây
            }
            
            // Gọi hàm thông báo khi có tin nhắn mới (ví dụ mẫu)
            notifyNewMessage();
        });
        // ----- JS CHO TOGGLE SUBMENU -----
        document.querySelectorAll('.nav-item.nav-dropdown > .nav-link').forEach(toggle => {
            toggle.addEventListener('click', function(e) {
                e.preventDefault();
                const parent = this.closest('.nav-dropdown');
                const submenu = parent.querySelector('.sidebar-submenu');
                
                // Đơn giản chỉ hiển thị/ẩn submenu
                if (submenu.style.display === 'block') {
                    submenu.style.display = 'none';
                } else {
                    submenu.style.display = 'block';
                }
            });
        });

        // Hiển thị submenu chứa link active khi load trang
        document.addEventListener('DOMContentLoaded', function() {
            const activeSubmenuItem = document.querySelector('.sidebar-submenu .nav-link.active');
            if (activeSubmenuItem) {
                const submenu = activeSubmenuItem.closest('.sidebar-submenu');
                if (submenu) {
                    submenu.style.display = 'block';
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>