@{
    ViewData["Title"] = "Lịch sử giao dịch";
}
<link rel="stylesheet" href="~/css/transaction-history.css" />

<div class="container-fluid px-4">
    <!-- Tiêu đề trang -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="text-primary mb-0 fw-bold">@ViewData["Title"]</h1>
            <p class="text-muted">Quản lý và theo dõi các giao dịch tài khoản của bạn</p>
        </div>
        <div>
            <button type="button" class="btn btn-outline-primary me-2">
                <i class="fas fa-download me-2"></i>Xuất Excel
            </button>
            <a href="/transactions/topup" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Nạp tiền
            </a>
        </div>
    </div>

    <!-- Bộ lọc tìm kiếm -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-3">Bộ lọc tìm kiếm</h5>
            <form id="searchForm">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Loại giao dịch</label>
                        <select class="form-select" id="transactionType">
                            <option value="" selected>Tất cả giao dịch</option>
                            <option value="nap-tien">Nạp tiền</option>
                            <option value="dang-ky-goi">Đăng ký gói</option>
                            <option value="rut-tien">Rút tiền</option>
                            <option value="hoan-tien">Hoàn tiền</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-select" id="status">
                            <option value="" selected>Tất cả trạng thái</option>
                            <option value="thanh-cong">Thành công</option>
                            <option value="dang-xu-ly">Đang xử lý</option>
                            <option value="that-bai">Thất bại</option>
                            <option value="bi-huy">Bị hủy</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Từ ngày</label>
                        <input type="date" class="form-control" id="fromDate">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Đến ngày</label>
                        <input type="date" class="form-control" id="toDate">
                    </div>
                    <div class="col-12 text-end">
                        <button type="button" class="btn btn-light me-2" id="resetBtn">
                            <i class="fas fa-redo me-1"></i>Đặt lại
                        </button>
                        <button type="submit" class="btn btn-primary" id="searchBtn">
                            <i class="fas fa-search me-1"></i>Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Tổng quan số dư -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-white-50">Số dư hiện tại</h6>
                    <h3 class="mb-0">2,450,000 VND</h3>
                    <div class="mt-3 small">
                        <span class="text-white-50">Cập nhật: </span>
                        <span>Hôm nay, 15:30</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-white-50">Tổng nạp</h6>
                    <h3 class="mb-0">+5,450,000 VND</h3>
                    <div class="progress mt-3" style="height: 5px;">
                        <div class="progress-bar bg-white" role="progressbar" style="width: 75%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-white-50">Tổng chi</h6>
                    <h3 class="mb-0">-3,000,000 VND</h3>
                    <div class="progress mt-3" style="height: 5px;">
                        <div class="progress-bar bg-white" role="progressbar" style="width: 45%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-white-50">Giao dịch gần đây</h6>
                    <h3 class="mb-0">6 giao dịch</h3>
                    <div class="mt-3 small">
                        <span class="text-white-50">Trong 7 ngày qua</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Danh sách giao dịch -->
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="card-title mb-0">Danh sách giao dịch</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" style="min-width: 120px">Mã giao dịch</th>
                            <th scope="col" style="min-width: 120px">Ngày giao dịch</th>
                            <th scope="col">Loại giao dịch</th>
                            <th scope="col">Mô tả</th>
                            <th scope="col">Số tiền</th>
                            <th scope="col">Trạng thái</th>
                            <th scope="col" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>#TX00123</td>
                            <td>20/04/2023<br><small class="text-muted">15:30</small></td>
                            <td>Nạp tiền</td>
                            <td>Nạp tiền vào tài khoản</td>
                            <td class="text-success fw-bold">+2,000,000 VND</td>
                            <td><span class="badge bg-success">Thành công</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>#TX00122</td>
                            <td>19/04/2023<br><small class="text-muted">09:15</small></td>
                            <td>Đăng tuyển</td>
                            <td>Đăng tin tuyển dụng: Kỹ sư phần mềm</td>
                            <td class="text-danger fw-bold">-500,000 VND</td>
                            <td><span class="badge bg-success">Thành công</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>#TX00121</td>
                            <td>18/04/2023<br><small class="text-muted">14:45</small></td>
                            <td>Đăng ký gói</td>
                            <td>Đăng ký gói Doanh nghiệp Pro - 3 tháng</td>
                            <td class="text-danger fw-bold">-5,000,000 VND</td>
                            <td><span class="badge bg-warning text-dark">Đang xử lý</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>#TX00120</td>
                            <td>15/04/2023<br><small class="text-muted">11:20</small></td>
                            <td>Rút tiền</td>
                            <td>Rút tiền về tài khoản ngân hàng</td>
                            <td class="text-danger fw-bold">-1,000,000 VND</td>
                            <td><span class="badge bg-danger">Thất bại</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>#TX00119</td>
                            <td>10/04/2023<br><small class="text-muted">08:30</small></td>
                            <td>Nạp tiền</td>
                            <td>Nạp tiền từ ví điện tử MoMo</td>
                            <td class="text-success fw-bold">+3,000,000 VND</td>
                            <td><span class="badge bg-success">Thành công</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>#TX00118</td>
                            <td>05/04/2023<br><small class="text-muted">16:45</small></td>
                            <td>Hoàn tiền</td>
                            <td>Hoàn tiền hủy đăng tin tuyển dụng</td>
                            <td class="text-success fw-bold">+450,000 VND</td>
                            <td><span class="badge bg-success">Thành công</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white">
            <nav>
                <ul class="pagination justify-content-center justify-content-md-end mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#"><i class="fas fa-chevron-left"></i></a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#"><i class="fas fa-chevron-right"></i></a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Chi tiết giao dịch -->
<div class="modal fade" id="transactionDetailModal" tabindex="-1" aria-labelledby="transactionDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="transactionDetailModalLabel">Chi tiết giao dịch #TX00123</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-2"><strong>Mã giao dịch:</strong> #TX00123</p>
                        <p class="mb-2"><strong>Loại giao dịch:</strong> Nạp tiền</p>
                        <p class="mb-2"><strong>Thời gian:</strong> 20/04/2023 15:30</p>
                        <p class="mb-2"><strong>Số tiền:</strong> <span class="text-success">+2,000,000 VND</span></p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-2"><strong>Phương thức thanh toán:</strong> Chuyển khoản ngân hàng</p>
                        <p class="mb-2"><strong>Ngân hàng:</strong> Vietcombank</p>
                        <p class="mb-2"><strong>Mã giao dịch ngân hàng:</strong> VCB123456789</p>
                        <p class="mb-2"><strong>Trạng thái:</strong> <span class="badge bg-success">Thành công</span></p>
                    </div>
                </div>
                <hr>
                <div class="mb-3">
                    <h6>Mô tả giao dịch</h6>
                    <p>Nạp tiền vào tài khoản HuitWorks từ tài khoản ngân hàng Vietcombank của Nguyễn Văn A.</p>
                </div>
                <div class="mb-3">
                    <h6>Lịch sử giao dịch</h6>
                    <div class="transaction-timeline">
                        <div class="d-flex mb-2">
                            <div class="me-3">
                                <div class="timeline-icon bg-success"><i class="fas fa-check"></i></div>
                            </div>
                            <div>
                                <p class="mb-0 fw-bold">Giao dịch hoàn tất</p>
                                <p class="mb-0 text-muted small">20/04/2023 15:35</p>
                            </div>
                        </div>
                        <div class="d-flex mb-2">
                            <div class="me-3">
                                <div class="timeline-icon bg-primary"><i class="fas fa-sync"></i></div>
                            </div>
                            <div>
                                <p class="mb-0 fw-bold">Đang xử lý</p>
                                <p class="mb-0 text-muted small">20/04/2023 15:32</p>
                            </div>
                        </div>
                        <div class="d-flex">
                            <div class="me-3">
                                <div class="timeline-icon bg-info"><i class="fas fa-plus"></i></div>
                            </div>
                            <div>
                                <p class="mb-0 fw-bold">Tạo giao dịch</p>
                                <p class="mb-0 text-muted small">20/04/2023 15:30</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary"><i class="fas fa-download me-1"></i>Tải biên lai</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(function() {
          // 1. Lấy element modal và append vào body để đảm bảo z-index
          var modalEl = document.getElementById('transactionDetailModal');
          if (modalEl && modalEl.parentNode !== document.body) {
            document.body.appendChild(modalEl);
          }

          // 2. Bắt click để show modal qua API của Bootstrap 5
          $('.btn-outline-primary').on('click', function() {
            var myModal = bootstrap.Modal.getOrCreateInstance(modalEl);
            myModal.show();
          });

          // 3. Các xử lý form tìm kiếm và reset
          $('#searchForm').on('submit', function(e) {
            e.preventDefault();
            console.log('Tìm kiếm với:', {
              type: $('#transactionType').val(),
              status: $('#status').val(),
              from: $('#fromDate').val(),
              to: $('#toDate').val()
            });
          });
          $('#resetBtn').on('click', function() {
            $('#transactionType, #status, #fromDate, #toDate').val('');
          });
        });
    </script>

    <style>
        /* override z-index nếu backdrop còn che modal */
        .modal-backdrop.show {
            z-index: 1040 !important;
        }

        .modal.show {
            z-index: 1050 !important;
        }
    </style>
}
